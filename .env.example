# ─── Image ────────────────────────────────────────────────────
IMAGE_NAME=ghcr.io/steven-baron/erpnext-crm
VERSION=16

# ─── Site ─────────────────────────────────────────────────────
SITE_NAME=erp.yourdomain.com
ADMIN_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me

# ─── Traefik ──────────────────────────────────────────────────
# Set to the Dokploy compose project network name.
# Find it with: docker compose ls  (the NAME column)
TRAEFIK_NETWORK=your-project-name

# Leave empty → nginx uses the Host header (correct for multi-site).
# Set to a hostname only for single-site setups.
FRAPPE_SITE_NAME_HEADER=

# bench-network subnet prefix. Each stack on the same host needs a UNIQUE one
# or Docker errors "Pool overlaps with other one on this address space".
# Production: 10.89.0 (default). A second/test stack: 10.90.0, etc.
NET_PREFIX=10.89.0

# ─── Feature flags ────────────────────────────────────────────
# Steady state (after first deploy)
ENABLE_DB=1
CONFIGURE=0
CREATE_SITE=0
MIGRATE=0
REGENERATE_APPS_TXT=0

# First deploy — enable these, then set back to 0 after site is created:
# CONFIGURE=1
# CREATE_SITE=1
# INSTALL_APP_ARGS=--install-app erpnext --install-app crm --install-app prospecting

# ─── Performance (optional overrides) ─────────────────────────
GUNICORN_WORKERS=8
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=150
PROXY_READ_TIMEOUT=150
